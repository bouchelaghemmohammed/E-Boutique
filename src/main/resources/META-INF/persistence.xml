<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="eboutiquePU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Detection automatique des classes annotees @Entity -->
        <exclude-unlisted-classes>false</exclude-unlisted-classes>

        <properties>
            <!-- Connexion MySQL -->
            <property name="jakarta.persistence.jdbc.driver"   value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:mysql://localhost:3306/eboutique?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user"     value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="root"/>

            <!-- Configuration Hibernate -->
            <property name="hibernate.dialect"      value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql"     value="true"/>
            <property name="hibernate.format_sql"   value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="validate"/>
            <!--
                hbm2ddl.auto :
                  - validate : verifie que le schema existe (recommande, schema.sql cree manuellement)
                  - update   : met a jour le schema (utile en dev)
                  - create   : recree tout a chaque demarrage (efface les donnees)
            -->
        </properties>
    </persistence-unit>

</persistence>
