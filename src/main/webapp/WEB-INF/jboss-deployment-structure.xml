<?xml version="1.0" encoding="UTF-8"?>
<!--
    Configuration WildFly :
    On exclut le module Hibernate fourni par WildFly pour utiliser
    la version embarquee dans le WAR (definie dans pom.xml).
    Cela evite les conflits de classloader entre 2 versions d'Hibernate.
-->
<jboss-deployment-structure xmlns="urn:jboss:deployment-structure:1.3">
    <deployment>
        <exclusions>
            <module name="org.hibernate"/>
            <module name="org.hibernate.envers"/>
        </exclusions>
        <!--
            Pas de dependance vers com.mysql : le driver JDBC MySQL est bundle
            dans WEB-INF/lib via la dependance Maven mysql-connector-j.
        -->
    </deployment>
</jboss-deployment-structure>
